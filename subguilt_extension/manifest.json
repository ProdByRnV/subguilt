{
  "manifest_version": 3,
  "name": "SubGuilt Tracker",
  "version": "1.0",
  "description": "Tracks active watch time on streaming platforms for the SubGuilt Predictor.",
  "permissions": [
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "*://*.netflix.com/*",
    "*://*.primevideo.com/*",
    "*://*.youtube.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.netflix.com/*",
        "*://*.primevideo.com/*",
        "*://*.youtube.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "SubGuilt"
  }
}